# Domain
DOMAIN=securia.ymad.fr

# Database
POSTGRES_USER=securibot
POSTGRES_PASSWORD=changeme_in_prod
POSTGRES_DB=securibot
DATABASE_URL=postgresql://securibot:changeme_in_prod@db:5432/securibot

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRODUCT_ID_AUDIT=prod_...

# NVIDIA
NVIDIA_API_KEY=nvapi-...
NEMOTRON_MODEL=nemotron-3-ultra
NEMOCLAW_ENABLED=true

# Hermes
HERMES_PROFILE=default
HERMES_MODEL=nvidia/nemotron-3-ultra

# Security
SECRET_KEY=your-secret-key-change-in-prod

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
